        <mxCell id="GTsWg-z-iIqdF2eWUMhV-23" parent="zgf1Y0MCejNMzzvRkMLo-151" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fontColor=#000000;strokeColor=none;fillColor=#1BADFF;gradientColor=none;align=center;verticalAlign=middle;fontSize=20;arcSize=50;spacing=0;spacingTop=0;fontStyle=1" value="&lt;font color=&quot;#ffffff&quot;&gt;&lt;span style=&quot;line-height: 100%;&quot;&gt;4&lt;/span&gt;&lt;/font&gt;" vertex="1">
