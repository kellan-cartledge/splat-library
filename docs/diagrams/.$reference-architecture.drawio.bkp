        <mxCell id="zgf1Y0MCejNMzzvRkMLo-168" parent="zgf1Y0MCejNMzzvRkMLo-151" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fontColor=#000000;strokeColor=none;fillColor=#1BADFF;gradientColor=none;align=center;verticalAlign=middle;fontSize=14;arcSize=50;spacing=0;spacingTop=0;" value="&lt;font color=&quot;#ffffff&quot;&gt;&lt;b&gt;11&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="24" width="24" x="2032" y="3155" as="geometry" />
        </mxCell>
        <mxCell id="zgf1Y0MCejNMzzvRkMLo-169" parent="zgf1Y0MCejNMzzvRkMLo-151" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" value="The frontend React app is hosted in an S3 bucket and served globally through CloudFront. CloudFront also proxies API requests and serves processed splat files and thumbnails from the S3 assets bucket." vertex="1">
          <mxGeometry height="80" width="280" x="2061" y="2406" as="geometry" />
        </mxCell>
        <mxCell id="zgf1Y0MCejNMzzvRkMLo-176" parent="zgf1Y0MCejNMzzvRkMLo-151" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" value="AWS Step Functions&lt;b&gt; &lt;/b&gt;provides a modular approach for&amp;nbsp;orchestrating tasks with error handling to process the uploaded video files into 3D splats." vertex="1">
          <mxGeometry height="59" width="280" x="2058" y="2752" as="geometry" />
        </mxCell>
        <mxCell id="zgf1Y0MCejNMzzvRkMLo-178" parent="zgf1Y0MCejNMzzvRkMLo-151" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fontColor=#000000;strokeColor=none;fillColor=#1BADFF;gradientColor=none;align=center;verticalAlign=middle;fontSize=20;arcSize=50;spacing=0;spacingTop=0;fontStyle=1" value="&lt;font color=&quot;#ffffff&quot;&gt;&lt;span style=&quot;line-height: 100%;&quot;&gt;5&lt;/span&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="36" width="36" x="931" y="2415" as="geometry" />
        </mxCell>
        <mxCell id="zgf1Y0MCejNMzzvRkMLo-179" parent="zgf1Y0MCejNMzzvRkMLo-151" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" value="A Lambda function state with an FFmpeg layer extracts frames from the uploaded video at the configured fps rate and writes them to S3." vertex="1">
          <mxGeometry height="58" width="280" x="2061" y="2817" as="geometry" />
        </mxCell>
        <mxCell id="zgf1Y0MCejNMzzvRkMLo-180" parent="zgf1Y0MCejNMzzvRkMLo-151" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fontColor=#000000;strokeColor=none;fillColor=#1BADFF;gradientColor=none;align=center;verticalAlign=middle;fontSize=14;arcSize=50;spacing=0;spacingTop=0;" value="&lt;font color=&quot;#ffffff&quot;&gt;&lt;b&gt;5&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="24" width="24" x="2031" y="2669" as="geometry" />
        </mxCell>
        <mxCell id="zgf1Y0MCejNMzzvRkMLo-182" parent="zgf1Y0MCejNMzzvRkMLo-151" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fontColor=#000000;strokeColor=none;fillColor=#1BADFF;gradientColor=none;align=center;verticalAlign=middle;fontSize=20;arcSize=50;spacing=0;spacingTop=0;fontStyle=1" value="&lt;font color=&quot;#ffffff&quot;&gt;&lt;span style=&quot;line-height: 100%;&quot;&gt;11&lt;/span&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="36" width="36" x="463" y="3148" as="geometry" />
        </mxCell>
        <mxCell id="zgf1Y0MCejNMzzvRkMLo-187" parent="zgf1Y0MCejNMzzvRkMLo-151" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" value="Users access the Splat Library web application from their browser. This tool allows users to easily create 3D gaussian splats of environments and objects by uploading videos." vertex="1">
          <mxGeometry height="69" width="280" x="2061" y="2329" as="geometry" />
        </mxCell>
        <mxCell id="zgf1Y0MCejNMzzvRkMLo-189" parent="zgf1Y0MCejNMzzvRkMLo-151" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" value="Amazon IAM, Amazon CloudWatch, and&lt;b&gt; &lt;/b&gt;AWS X-ray&lt;b&gt; &lt;/b&gt;provide management, monitoring, and observability for the solution." vertex="1">
          <mxGeometry height="57" width="280" x="2061" y="3153" as="geometry" />
        </mxCell>
        <mxCell id="zgf1Y0MCejNMzzvRkMLo-192" parent="zgf1Y0MCejNMzzvRkMLo-151" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" value="AWS Lambda&lt;b&gt;&amp;nbsp;&lt;/b&gt;proxy functions handle the business logic of the API endpoints. This enhances scalability of the application by spreading requests across top-level endpoints: /scenes, /upload, and /jobs." vertex="1">
          <mxGeometry height="66" width="280" x="2058" y="2586" as="geometry" />
        </mxCell>
        <mxCell id="zgf1Y0MCejNMzzvRkMLo-193" parent="zgf1Y0MCejNMzzvRkMLo-151" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fontColor=#000000;strokeColor=none;fillColor=#1BADFF;gradientColor=none;align=center;verticalAlign=middle;fontSize=14;arcSize=50;spacing=0;spacingTop=0;" value="&lt;font color=&quot;#ffffff&quot;&gt;&lt;b&gt;4&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="24" width="24" x="2031" y="2587" as="geometry" />
        </mxCell>
        <mxCell id="zgf1Y0MCejNMzzvRkMLo-195" parent="zgf1Y0MCejNMzzvRkMLo-151" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fontColor=#000000;strokeColor=none;fillColor=#1BADFF;gradientColor=none;align=center;verticalAlign=middle;fontSize=14;arcSize=50;spacing=0;spacingTop=0;" value="&lt;font color=&quot;#ffffff&quot;&gt;&lt;b&gt;8&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="24" width="24" x="2031" y="2885" as="geometry" />
        </mxCell>
        <mxCell id="zgf1Y0MCejNMzzvRkMLo-196" parent="zgf1Y0MCejNMzzvRkMLo-151" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;labelBackgroundColor=none;fontColor=#000000;" value="An AWS Batch job runs the gsplat training container on GPU Spot instances. Training runs for a configurable number of iterations with adaptive densification, producing a PLY point cloud in the outputs/ prefix in S3." vertex="1">
          <mxGeometry height="79" width="280" x="2061" y="2979" as="geometry" />
        </mxCell>
        <mxCell id="zgf1Y0MCejNMzzvRkMLo-199" parent="zgf1Y0MCejNMzzvRkMLo-151" style="text;whiteSpace=wrap;html=1;" value="An AWS Batch job runs the COLMAP container on GPU Spot instances to perform Structure-from-Motion (SfM), estimating camera poses. The sparse reconstruction is written to the colmap/ prefix in S3." vertex="1">
          <mxGeometry height="75" width="273" x="2062" y="2883" as="geometry" />
        </mxCell>
